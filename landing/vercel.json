{
    "rewrites": [
        {
            "source": "/api/update/:platform/:version",
            "destination": "/api/update/latest.json"
        }
    ],
    "headers": [
        {
            "source": "/api/update/latest.json",
            "headers": [
                { "key": "Cache-Control", "value": "s-maxage=0, no-cache, no-store, must-revalidate" },
                { "key": "Access-Control-Allow-Origin", "value": "*" }
            ]
        }
    ]
}
