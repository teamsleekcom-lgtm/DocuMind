{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "DocuMind",
    "version": "1.0.0",
    "identifier": "app.documind.desktop",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev -- --mode desktop",
        "beforeBuildCommand": "node scripts/build-provisioner.mjs && npm run build -- --mode desktop"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "DocuMind",
                "width": 1280,
                "height": 800,
                "resizable": true,
                "fullscreen": false,
                "visible": false,
                "additionalBrowserArgs": "--enable-features=CertVerifierBuiltinFeature"
            },
            {
                "label": "splash",
                "title": "DocuMind Loading",
                "width": 400,
                "height": 200,
                "decorations": false,
                "center": true,
                "resizable": false,
                "alwaysOnTop": true,
                "url": "/splash.html"
            }
        ]
    },
    "bundle": {
        "active": true,
        "publisher": "DocuMind Contributors",
        "targets": [
            "deb",
            "rpm",
            "dmg",
            "msi"
        ],
        "icon": [
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/16x16.png",
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/192x192.png"
        ],
        "resources": [
            "libs/*.jar",
            "runtime/jre/**/*"
        ],
        "fileAssociations": [
            {
                "ext": [
                    "pdf"
                ],
                "name": "PDF Document",
                "role": "Editor",
                "mimeType": "application/pdf"
            }
        ],
        "linux": {
            "deb": {
                "desktopTemplate": "stirling-pdf.desktop"
            }
        },
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": "http://timestamp.digicert.com",
            "wix": {
                "fragmentPaths": [
                    "windows/wix/provisioning.wxs"
                ],
                "componentGroupRefs": [
                    "ProvisioningComponentGroup"
                ]
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.15",
            "signingIdentity": null,
            "entitlements": null,
            "providerShortName": null,
            "infoPlist": "Info.plist"
        }
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "fs": {
            "requireLiteralLeadingDot": false
        },
        "deep-link": {
            "desktop": {
                "schemes": [
                    "stirlingpdf"
                ]
            }
        }
    }
}
